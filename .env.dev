spring.config.activate.on-profile=dev

# Variables d'environnement (déploiement)
DB_URL=3306
DB_USER=root
DB_PASS=root
FRONTEND_URL=http://localhost:8080

# JWT
JWT_SECRET=DEV_ULTRA_LONG_SECRET_KEY_AT_LEAST_64_CHARS__

MAIL_HOST=exemple@exemple.com
MAIL_PORT=500
