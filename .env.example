# DATABASE (MySQL - Docker)
MYSQL_DATABASE=meetmates
MYSQL_USER=example_user
MYSQL_PASSWORD=example_password
MYSQL_ROOT_PASSWORD=example_root_password

# SPRING BOOT DATASOURCE
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:1234/meetmates?useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=example_user
SPRING_DATASOURCE_PASSWORD=example_password

# JWT CONFIGURATION
APP_JWT_SECRET=jwt_secret_key

# FRONTEND URL
APP_FRONTEND_URL=http://localhost:4200

# MAIL 
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=123
SPRING_MAIL_USERNAME=[your_email@example.com](mailto:your_email@example.com)
SPRING_MAIL_PASSWORD=your_email_password

SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

APP_MAIL_FROM=[no-reply@example.com](mailto:no-reply@example.com)

MAIL_HOST=example.com
MAIL_PORT=123
MAIL_USER=[your_email@example.com](mailto:your_email@example.com)
MAIL_PASS=your_email_password

